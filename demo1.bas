10 REM ZX SPECTRUM DEMO 1
20 BORDER 0: PAPER 0: INK 0: CLS
30 PRINT AT 10,8;INK 7;BRIGHT 1;"ZX SPECTRUM DEMO"
40 PAUSE 120
50 CLS
60 REM PHASE 1: FILL WITH RANDOM LETTERS
70 FOR i=1 TO 500
80 PRINT AT INT(RND*22),INT(RND*32);INK INT(RND*7)+1;CHR$(65+INT(RND*26))
90 NEXT i
100 PAUSE 80
110 REM PHASE 2: ATTRIBUTE SCROLL DOWN
120 FOR t=1 TO 24
130 FOR r=22 TO 0 STEP -1
140 FOR c=0 TO 31
150 POKE 22528+(r+1)*32+c,PEEK(22528+r*32+c)
160 NEXT c
170 NEXT r
180 FOR c=0 TO 31
190 POKE 22528+c,(INT(RND*7)+1)+(INT(RND*6)+1)*8+64
200 NEXT c
210 NEXT t
220 PAUSE 60
230 REM PHASE 3: RAINBOW WAVE
240 FOR t=0 TO 55
250 FOR r=0 TO 23
260 LET k=r+t-INT((r+t)/8)*8
270 FOR c=0 TO 31
280 POKE 22528+r*32+c,INT(PEEK(22528+r*32+c)/8)*8+k
290 NEXT c
300 NEXT r
310 PAUSE 3
320 NEXT t
330 PAUSE 30
340 REM PHASE 4: FLASH SWEEP
350 FOR t=0 TO 23
360 FOR c=0 TO 31
370 LET a=22528+t*32+c
380 LET v=PEEK a
390 IF v<128 THEN POKE a,v+128
400 NEXT c
410 PAUSE 2
420 NEXT t
430 PAUSE 50
440 REM PHASE 5: BORDER STROBE
450 FOR p=1 TO 6
460 FOR t=0 TO 7
470 BORDER t
480 PAUSE 2
490 NEXT t
500 NEXT p
510 BORDER 0
520 PRINT AT 21,6;INK 7;"PRESS ANY KEY TO END"
530 PAUSE 0
