10 REM ZX SPECTRUM DEMO 1
20 BORDER 0: PAPER 0: INK 0: CLS
30 PRINT AT 10,8; INK 7; BRIGHT 1;"ZX SPECTRUM DEMO"
40 PAUSE 120
50 CLS
60 REM PHASE 1: FILL WITH RANDOM LETTERS
70 FOR i=1 TO 500
80 PRINT AT INT(RND*24),INT(RND*32);INK INT(RND*7)+1;CHR$(65+INT(RND*26))
90 NEXT i
100 PAUSE 80
110 REM PHASE 2: LETTER SCROLL
120 REM SCROLLS ATTRIBUTE COLOURS DOWNWARD THROUGH THE LETTERS
130 FOR t=1 TO 24
140 FOR r=22 TO 0 STEP -1
150 FOR c=0 TO 31
160 POKE 22528+(r+1)*32+c,PEEK(22528+r*32+c)
170 NEXT c
180 NEXT r
190 FOR c=0 TO 31
200 POKE 22528+c,(INT(RND*7)+1)+(INT(RND*6)+1)*8+64
210 NEXT c
220 NEXT t
230 PAUSE 60
240 REM PHASE 3: RAINBOW WAVE
250 REM CYCLES INK COLOUR ROW BY ROW TO CREATE A MOVING RAINBOW
260 FOR t=0 TO 55
270 FOR r=0 TO 23
280 LET k=(r+t) AND 7
290 FOR c=0 TO 31
300 POKE 22528+r*32+c,(PEEK(22528+r*32+c) AND 248) OR k
310 NEXT c
320 NEXT r
330 PAUSE 3
340 NEXT t
350 PAUSE 30
360 REM PHASE 4: BRIGHT FLASH SWEEP
370 FOR t=0 TO 23
380 FOR c=0 TO 31
390 LET a=22528+t*32+c
400 POKE a,PEEK a OR 128
410 NEXT c
420 PAUSE 2
430 NEXT t
440 PAUSE 50
450 REM PHASE 5: BORDER STROBE
460 FOR t=0 TO 48
470 BORDER t AND 7
480 PAUSE 2
490 NEXT t
500 BORDER 0
510 PRINT AT 23,6;INK 7;"PRESS ANY KEY TO END"
520 PAUSE 0
